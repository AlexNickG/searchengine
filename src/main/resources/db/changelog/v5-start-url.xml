<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="6" author="Alex">
        <!-- url may be a long domain+path used as boundary key, TEXT is safer -->
        <modifyDataType tableName="site_config" columnName="url" newDataType="TEXT"/>
        <!-- optional: the actual page to start crawling from (null = same as url) -->
        <addColumn tableName="site_config">
            <column name="start_url" type="TEXT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>